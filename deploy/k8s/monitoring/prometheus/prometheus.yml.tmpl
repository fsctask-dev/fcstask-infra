global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    cluster: fcstask-local
    env: dev

rule_files:
  - rules.yml

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ["localhost:9090"]

  - job_name: fcstask-backend
    metrics_path: /metrics
    static_configs:
      - targets: ["host.docker.internal:8081"]

  - job_name: sql-exporter
    static_configs:
      - targets: ["sql-exporter:9399"]

  - job_name: postgres-exporter
    static_configs:
      - targets: ["postgres-exporter:9187"]

alerting:
  alertmanagers:
    - static_configs:
        - targets: ["alertmanager:9093"]

remote_write:
  - url: ${GRAFANA_CLOUD_REMOTE_WRITE_URL}
    basic_auth:
      username: ${GRAFANA_CLOUD_REMOTE_WRITE_USERNAME}
      password: ${GRAFANA_CLOUD_REMOTE_WRITE_PASSWORD}
    write_relabel_configs:
      - source_labels: [__name__]
        regex: 'go_gc_pauses_seconds_bucket'
        action: drop
